<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black"
    android:keepScreenOn="true">

    <!-- Back image (fades out) -->
    <ImageView
        android:id="@+id/image_back"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:contentDescription="@null" />

    <!-- Front image (fades in) -->
    <ImageView
        android:id="@+id/image_front"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:contentDescription="@null" />

    <!-- Metadata bar (bottom of screen, above images) -->
    <TextView
        android:id="@+id/metadata_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#99000000"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:textColor="#DDDDDD"
        android:textSize="13sp"
        android:singleLine="true"
        android:ellipsize="end"
        android:visibility="gone" />

    <!-- Clock overlay (top-left) -->
    <LinearLayout
        android:id="@+id/clock_overlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_margin="16dp"
        android:orientation="vertical"
        android:background="#66000000"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:visibility="gone">

        <TextClock
            android:id="@+id/clock_digital_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:format12Hour="h:mm a"
            android:format24Hour="HH:mm"
            android:textColor="#FFFFFF"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextClock
            android:id="@+id/clock_digital_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:format12Hour="EEE, MMM d"
            android:format24Hour="EEE, MMM d"
            android:textColor="#CCCCCC"
            android:textSize="14sp" />

        <red.henry.skymmich.AnalogClockView
            android:id="@+id/clock_analog"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_marginTop="4dp"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Weather overlay (top-right) -->
    <LinearLayout
        android:id="@+id/weather_overlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_margin="16dp"
        android:orientation="vertical"
        android:gravity="end"
        android:background="#66000000"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/weather_temp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/weather_desc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#CCCCCC"
            android:textSize="13sp" />

    </LinearLayout>

    <!-- Settings overlay -->
    <ScrollView
        android:id="@+id/settings_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#EE000000"
        android:visibility="visible"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="32dp"
            android:focusable="true"
            android:focusableInTouchMode="true">

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_subtitle"
                android:textColor="#AAAAAA"
                android:textSize="14sp"
                android:layout_marginBottom="24dp" />

            <!-- ── Server ── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="— Server —"
                android:textColor="#4488FF"
                android:textSize="12sp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/label_server_url"
                android:textColor="#CCCCCC"
                android:textSize="13sp"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/edit_server_url"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="@string/hint_server_url"
                android:textColor="#FFFFFF"
                android:textColorHint="#666666"
                android:background="#33FFFFFF"
                android:padding="12dp"
                android:textSize="15sp"
                android:inputType="textUri"
                android:singleLine="true"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/label_api_key"
                android:textColor="#CCCCCC"
                android:textSize="13sp"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/edit_api_key"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="@string/hint_api_key"
                android:textColor="#FFFFFF"
                android:textColorHint="#666666"
                android:background="#33FFFFFF"
                android:padding="12dp"
                android:textSize="15sp"
                android:inputType="textVisiblePassword"
                android:singleLine="true"
                android:layout_marginBottom="20dp" />

            <!-- ── Albums ── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="— Albums —"
                android:textColor="#4488FF"
                android:textSize="12sp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/label_album_ids"
                android:textColor="#CCCCCC"
                android:textSize="13sp"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/edit_album_ids"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="@string/hint_album_ids"
                android:textColor="#FFFFFF"
                android:textColorHint="#666666"
                android:background="#33FFFFFF"
                android:padding="12dp"
                android:textSize="15sp"
                android:inputType="text"
                android:singleLine="true"
                android:layout_marginBottom="20dp" />

            <!-- ── Slideshow ── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="— Slideshow —"
                android:textColor="#4488FF"
                android:textSize="12sp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/label_interval"
                android:textColor="#CCCCCC"
                android:textSize="13sp"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/edit_interval"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="@string/hint_interval"
                android:textColor="#FFFFFF"
                android:textColorHint="#666666"
                android:background="#33FFFFFF"
                android:padding="12dp"
                android:textSize="15sp"
                android:inputType="number"
                android:singleLine="true"
                android:layout_marginBottom="20dp" />

            <!-- ── Overlays ── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="— Overlays —"
                android:textColor="#4488FF"
                android:textSize="12sp"
                android:layout_marginBottom="8dp" />

            <!-- Metadata toggle -->
            <CheckBox
                android:id="@+id/check_show_metadata"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/label_show_metadata"
                android:textColor="#CCCCCC"
                android:textSize="14sp"
                android:buttonTint="#4488FF"
                android:layout_marginBottom="12dp" />

            <!-- Clock toggle -->
            <CheckBox
                android:id="@+id/check_show_clock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/label_show_clock"
                android:textColor="#CCCCCC"
                android:textSize="14sp"
                android:buttonTint="#4488FF"
                android:layout_marginBottom="4dp" />

            <RadioGroup
                android:id="@+id/radio_clock_style"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginStart="16dp"
                android:layout_marginBottom="12dp">

                <RadioButton
                    android:id="@+id/radio_clock_digital"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_clock_digital"
                    android:textColor="#CCCCCC"
                    android:buttonTint="#4488FF"
                    android:layout_marginEnd="16dp" />

                <RadioButton
                    android:id="@+id/radio_clock_analog"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_clock_analog"
                    android:textColor="#CCCCCC"
                    android:buttonTint="#4488FF"
                    android:layout_marginEnd="16dp" />

                <RadioButton
                    android:id="@+id/radio_clock_both"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_clock_both"
                    android:textColor="#CCCCCC"
                    android:buttonTint="#4488FF" />

            </RadioGroup>

            <!-- Weather toggle -->
            <CheckBox
                android:id="@+id/check_show_weather"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/label_show_weather"
                android:textColor="#CCCCCC"
                android:textSize="14sp"
                android:buttonTint="#4488FF"
                android:layout_marginBottom="4dp" />

            <LinearLayout
                android:id="@+id/weather_fields"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/label_weather_location"
                    android:textColor="#CCCCCC"
                    android:textSize="13sp"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/edit_weather_location"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="@string/hint_weather_location"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#666666"
                    android:background="#33FFFFFF"
                    android:padding="12dp"
                    android:textSize="15sp"
                    android:inputType="text"
                    android:singleLine="true"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/label_weather_api_key"
                    android:textColor="#CCCCCC"
                    android:textSize="13sp"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/edit_weather_api_key"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="@string/hint_weather_api_key"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#666666"
                    android:background="#33FFFFFF"
                    android:padding="12dp"
                    android:textSize="15sp"
                    android:inputType="textVisiblePassword"
                    android:singleLine="true" />

            </LinearLayout>

            <!-- ── ADB over Network ── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="— ADB over Network —"
                android:textColor="#4488FF"
                android:textSize="12sp"
                android:layout_marginBottom="8dp" />

            <CheckBox
                android:id="@+id/check_adb_over_network"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/label_adb_over_network"
                android:textColor="#CCCCCC"
                android:textSize="14sp"
                android:buttonTint="#4488FF"
                android:layout_marginBottom="4dp" />

            <LinearLayout
                android:id="@+id/adb_port_fields"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/label_adb_port"
                    android:textColor="#CCCCCC"
                    android:textSize="13sp"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/edit_adb_port"
                    android:layout_width="120dp"
                    android:layout_height="48dp"
                    android:hint="@string/hint_adb_port"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#666666"
                    android:background="#33FFFFFF"
                    android:padding="12dp"
                    android:textSize="15sp"
                    android:inputType="number"
                    android:singleLine="true" />

            </LinearLayout>

            <!-- Save button -->
            <Button
                android:id="@+id/btn_save"
                android:layout_width="200dp"
                android:layout_height="48dp"
                android:text="@string/btn_save"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:background="#4488FF"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/status_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#FF6666"
                android:textSize="13sp"
                android:layout_marginTop="8dp" />

        </LinearLayout>
    </ScrollView>

</FrameLayout>
